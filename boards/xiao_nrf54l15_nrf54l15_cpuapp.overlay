#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
    chosen {
        /* Gebruik de IEEE802154 radio als Thread L2 */
        zephyr,ieee802154 = &ieee802154;
    };

    aliases {
        /* Alias voor 1-Wire */
        onewire0 = &onewire0;

        /* Alias voor C-kant: DT_ALIAS(i2c0) → &i2c22 */
        i2c0 = &i2c22;
    };

    /* -------------------------------------------------------
     * OneWire op GPIO2.2
     * ------------------------------------------------------- */
    onewire0: w1 {
        compatible = "zephyr,w1-gpio";
        gpios = <&gpio2 2 (GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
        status = "okay";
    };
};

/* -----------------------------------------------------------
 * Thread radio (802.15.4)
 * ----------------------------------------------------------- */
&ieee802154 {
    status = "okay";
};

/* -----------------------------------------------------------
 * UARTs
 * ----------------------------------------------------------- */
&uart20 {
    status = "okay";
    current-speed = <1000000>;
};

&uart21 {
    status = "disabled";
};

/* -----------------------------------------------------------
 * I2C22 bus → P1.11 (SCL), P1.10 (SDA)
 * ----------------------------------------------------------- */
&i2c22 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;

    pinctrl-0 = <&i2c22_default>;
    pinctrl-1 = <&i2c22_sleep>;
    pinctrl-names = "default", "sleep";

    /* SHT41 (0x44) */
    sht4x0: sht4x@44 {
        compatible = "sensirion,sht4x";
        reg = <0x44>;
        repeatability = <2>; /* High precision */
        status = "okay";
        
    };

    /* SCD41 CO2 sensor (0x62) */
    scd41_0: scd41@62 {
        compatible = "sensirion,scd41";
        reg = <0x62>;
        mode = <1>;   /* 1 = periodic measurement mode */
        status = "okay";
    };
};

/* -----------------------------------------------------------
 * Pinctrl for I2C22
 * ----------------------------------------------------------- */
&pinctrl {
    /omit-if-no-ref/ i2c22_default: i2c22_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 1, 11)>,
                    <NRF_PSEL(TWIM_SDA, 1, 10)>;
        };
    };

    /omit-if-no-ref/ i2c22_sleep: i2c22_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 1, 11)>,
                    <NRF_PSEL(TWIM_SDA, 1, 10)>;
            low-power-enable;
        };
    };
};