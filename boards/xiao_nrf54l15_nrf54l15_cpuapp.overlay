#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
    chosen {
        zephyr,ieee802154 = &ieee802154;
    };

    aliases {
        onewire0 = &onewire0;
        i2c0     = &i2c22;
    };

    /* 1-Wire bus on GPIO2.2 (D10 on XIAO).
     * No child DS18B20 nodes — sensors are discovered at runtime
     * via w1_search_bus() in onewire_inventory.c */
    onewire0: w1 {
        compatible = "zephyr,w1-gpio";
        gpios = <&gpio2 2 (GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
        status = "okay";
    };
};

/* -----------------------------------------------------------
 * Thread radio (802.15.4)
 * ----------------------------------------------------------- */
&ieee802154 {
    status = "okay";
};

/* -----------------------------------------------------------
 * UARTs
 * ----------------------------------------------------------- */
&uart20 {
    status = "okay";
    current-speed = <1000000>;
};

&uart21 {
    status = "disabled";
};

/* -----------------------------------------------------------
 * I2C22 bus → P1.11 (SCL), P1.10 (SDA)
 * ----------------------------------------------------------- */
&i2c22 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;
    pinctrl-0 = <&i2c22_default>;
    pinctrl-1 = <&i2c22_sleep>;
    pinctrl-names = "default", "sleep";

    sht4x0: sht4x@44 {
        compatible = "sensirion,sht4x";
        reg = <0x44>;
        repeatability = <2>;
        status = "okay";
    };

    scd41_0: scd41@62 {
        compatible = "sensirion,scd41";
        reg = <0x62>;
        mode = <1>;
        status = "okay";
    };
};

/* -----------------------------------------------------------
 * Pinctrl for I2C22
 * ----------------------------------------------------------- */
&pinctrl {
    /omit-if-no-ref/ i2c22_default: i2c22_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 1, 11)>,
                    <NRF_PSEL(TWIM_SDA, 1, 10)>;
        };
    };

    /omit-if-no-ref/ i2c22_sleep: i2c22_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 1, 11)>,
                    <NRF_PSEL(TWIM_SDA, 1, 10)>;
            low-power-enable;
        };
    };
};
