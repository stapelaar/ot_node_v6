menu "App options"

config APP_DEBUG_SENSOR
    bool "Log sensor detection and readouts"
    default y

config APP_DEBUG_TRANSPORT
    bool "Log CoAP publishes (topic and result code)"
    default y

config APP_TRANSPORT_COAP
    bool "Use CoAP transport"
    default y

config APP_PUBLISH_UPTIME
    bool "Publish uptime"
    default y

config APP_USE_SHT41_SENSOR
    bool "Use SHT41 sensor (I2C temp/humidity)"
    default n

config APP_USE_SCD41_SENSOR
    bool "Use SCD41 sensor (I2C CO2/temp/humidity)"
    default n

config APP_USE_DS18B20_SENSOR
    bool "Use DS18B20 sensor (1-Wire temperature)"
    default n

config APP_USE_MAX31850_SENSOR
    bool "Use MAX31850 sensor (1-Wire thermocouple)"
    default n

config APP_NODE_ID
    string "Node ID (e.g. 12 -> ND12)"
    default "00"

config APP_MEASUREMENT_PERIOD_S
    int "Measurement period (seconds)"
    default 60
    range 1 86400

config APP_COAP_ACK_TIMEOUT_MS
    int "CoAP ACK initial timeout (ms)"
    default 800
    range 100 5000

config APP_COAP_RETRIES
    int "CoAP CON retries"
    default 3
    range 0 8

endmenu

source "Kconfig.zephyr"
